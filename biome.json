{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "files": {
    "includes": ["src/**", "tests/**", "plugins/**", "tooling/**/*.mjs", "!**/*.css"]
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "enabled": false
  },
  "assist": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "error",
        "useExhaustiveDependencies": "warn"
      },
      "style": {
        "useConst": "error",
        "useImportType": "error",
        "noParameterAssign": "error",
        "noNonNullAssertion": "off"
      },
      "suspicious": {
        "noVar": "error",
        "noExplicitAny": "error",
        "noDoubleEquals": "error",
        "noConsole": {
          "level": "warn",
          "options": {
            "allow": ["warn", "error", "info"]
          }
        }
      },
      "a11y": {
        "useValidAriaRole": {
          "level": "error",
          "options": {
            "ignoreNonDom": true
          }
        },
        "useSemanticElements": "off"
      },
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "warn",
          "options": {
            "maxAllowedComplexity": 25
          }
        },
        "useSimplifiedLogicExpression": "warn"
      },
      "security": {
        "noGlobalEval": "error"
      },
      "nursery": {
        "noImpliedEval": "error",
        "noFloatingPromises": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": ["src/shared/components/DataTable/DataTable.tsx"],
      "linter": { "enabled": false }
    },
    {
      "includes": [
        "src/**/*.test.ts",
        "src/**/*.test.tsx",
        "src/**/__tests__/**",
        "tests/**"
      ],
      "linter": {
        "rules": {
          "nursery": {
            "noFloatingPromises": "off"
          },
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          }
        }
      }
    },
    {
      "includes": ["tooling/**/*.mjs", "plugins/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off",
            "noAssignInExpressions": "off"
          },
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          },
          "nursery": {
            "noFloatingPromises": "off"
          }
        }
      }
    },
    {
      "includes": ["src/shared/components/ui/**"],
      "linter": {
        "rules": {
          "security": {
            "noDangerouslySetInnerHtml": "off"
          },
          "a11y": {
            "useFocusableInteractive": "off",
            "useAriaPropsForRole": "off"
          }
        }
      }
    }
  ]
}
