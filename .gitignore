# Dependencies
node_modules
package-lock.json

# pnpm local store (cache) — may appear at root with some pnpm versions/configs
.pnpm-store

# Build output
dist
dist-ssr

# Env files — only .env.example is committed (template for required vars)
.env
.env.local
.env.development
.env.production
.env.staging
.env.qa
.env.*.local
.env.sentry-build-plugin
!.env.example
*.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Test artifacts (E2E: artifacts + HTML report under test-results/)
coverage
test-results
playwright-report
blob-report
.stryker-tmp

# Generated reports (code review, mutation, etc.) — generated by scripts, not hand-authored
reports/code-review
reports/mutation

# Security scan cache
.semgrep/

# Bundle analysis (generated)
dist/stats.html

# Editor directories and files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*~

# Netlify CLI local state (canonical config is root netlify.toml)
.netlify/state.json
.netlify/netlify.toml

# Husky internal hook router (auto-generated by `husky install`; only the hooks we author are tracked)
.husky/_

# Sentry
.sentryclirc

# agent-os — machine-local MCP config (contains API keys; use agent-os/mcp/mcp.example.json as template)
# .cursor/mcp.json and .mcp.json are symlinks into this file — keep them tracked so the layout survives clones.
agent-os/mcp/mcp.json
