# Dependencies
node_modules
package-lock.json

# pnpm local store (cache) — may appear at root with some pnpm versions/configs
.pnpm-store

# Build output
dist
dist-ssr
.size-limit.generated.json

# Env files — only .env.example is committed (template for required vars)
.env
.env.local
.env.development
.env.production
.env.staging
.env.qa
.env.*.local
.env.sentry-build-plugin
!.env.example
*.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Test artifacts (E2E: artifacts + HTML report under test-results/)
coverage
test-results
tests/e2e/.e2e-auth-headers.json
playwright-report
blob-report
.stryker-tmp

# Generated reports (code review, mutation, etc.) — generated by scripts, not hand-authored
reports/code-review
reports/mutation

# Security scan cache
.semgrep/

# Bundle analysis (generated)
dist/stats.html

# Editor directories and files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*~

# Netlify CLI local state (canonical config is root netlify.toml)
.netlify/state.json
.netlify/netlify.toml

# Husky internal hook router (auto-generated by `husky install`; only the hooks we author are tracked)
.husky/_

# Sentry
.sentryclirc

# Scaffold `.mcp.json` with `pnpm mcp:setup` (full) / `pnpm mcp:setup:default` (pair),
# or let `pnpm setup:local` declare the default pair for you.
.cursor/mcp.json
.mcp.json
agent-os/mcp/mcp.json

# Claude Code — machine-local permission overrides (merges with agent-os/platforms/claude/settings.json)
.claude/settings.local.json

# codegraph — local code-intelligence index (rebuilt via `codegraph init` / `codegraph sync`;
# auto-refreshed on branch switch + merge/pull by the .husky/post-checkout + post-merge hooks;
# machine-local, not shared)
.codegraph/

# Supply-chain inventory (generated by pnpm sbom:generate)
sbom.cyclonedx.json

# Generated API reference (pnpm docs:api)
docs/api/
