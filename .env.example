# ─────────────────────────────────────────────────────────────────────────────
# Core Frontend — Environment variables reference (the ONLY committed env file)
# `pnpm setup:local` scaffolds .env.local from this. One `.env.<NODE_ENV>` file per
# environment (mirrors core-be): .env.local (local dev — the default), .env.development
# + .env.production (the two DEPLOY environments). Local dev runs in `local` mode;
# deploys inject env from GitHub Environments.
# Canonical runbook: docs/deployment/runbooks/environment-variables.md
#
# The `# comment` above each key is its description — single-sourced from
# `envFieldDescriptions` in src/core/config/env-schema.ts and kept identical by
# `pnpm tool:sync-env-example` (it fails on drift). Two DEPLOY environments —
# development and production (local is not a deploy target). Branch-wise contracts
# (envProfiles, enforced by `pnpm validate:client-env`): main → production. Each declares
# required keys, forbidden keys (SONAR_*, wrong-env Stripe), and STRICT allowed
# values (e.g. production pins diagnostics off, VITE_VERSION_CHECK on).
# ─────────────────────────────────────────────────────────────────────────────

# ############################################################
# GitHub Secrets (Netlify / GitHub Actions — sensitive)
# ############################################################

# --- Build / deploy ---
# Sentry source-map upload token (CI only); see docs/integrations/sentry-sourcemaps.md.
SENTRY_AUTH_TOKEN=
# Sentry organization slug (source-map upload).
SENTRY_ORG=
# Sentry project slug (source-map upload).
SENTRY_PROJECT=
# Netlify CLI deploy token (CI only).
NETLIFY_AUTH_TOKEN=

# --- Local MCP (Cursor / Claude — not bundled into the app) ---
# Context7 docs-MCP API key; consumed by .mcp.json for the docs MCP (local tooling).
CONTEXT7_API_KEY=

# --- Local SonarQube quality gate (development only — never set in CI) ---
# Local SonarQube admin password; auto-managed by tooling/sonar/sonar-gate.mjs (never in CI).
SONAR_ADMIN_PASSWORD=
# Local SonarQube scanner token; auto-managed by the sonar gate (never in CI).
SONAR_TOKEN=

# ############################################################
# GitHub Variables (public or operational knobs)
# ############################################################

# --- API ---
# Production API base URL (e.g. https://api.example.com); empty = same-origin. Required in production when the API is not same-origin.
VITE_API_BASE_URL=
# Dev server only: Vite proxy target for /api.
VITE_DEV_API_URL=http://localhost:3000

# --- Observability (public client keys) ---
# Sentry DSN (public client key); empty disables Sentry.
VITE_SENTRY_DSN=
# Sentry traces sample rate 0..1 (prod-safe default 0.1).
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# Sentry session-replay sample rate 0..1 (prod-safe default 0.1).
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
# Sentry profiles sample rate 0..1 (default 1.0).
VITE_SENTRY_PROFILES_SAMPLE_RATE=1.0
# Sentry on-error replay sample rate 0..1 (default 1.0).
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0
# PostHog project key (optional); analytics is gated behind consent.
VITE_POSTHOG_KEY=
# PostHog host (optional); pairs with VITE_POSTHOG_KEY.
VITE_POSTHOG_HOST=
# CSP violation report collector URI (optional).
VITE_CSP_REPORT_URI=

# --- Payments (public client key) ---
# Stripe publishable key (pk_test_ in dev, pk_live_ in prod); public, safe to expose.
VITE_STRIPE_PUBLISHABLE_KEY=

# --- App chrome ---
# App layout width: contained (default), full, or reading.
VITE_LAYOUT_WIDTH=contained
# "true" hides the runtime theme switcher + shuffle.
VITE_THEME_LOCK=
# Privacy-policy URL shown in the consent banner/footer (optional).
VITE_PRIVACY_POLICY_URL=

# --- Platform: feature modules ---
# Comma-separated module keys to disable (e.g. billing,members); routes 404 via the module gate.
VITE_DISABLED_MODULES=
# Tri-state override for personal-org deployment mode (true/false/unset).
VITE_PERSONAL_ORGANIZATIONS=
# Tri-state override for team-org deployment mode (true/false/unset).
VITE_TEAM_ORGANIZATIONS=

# --- Platform: auth methods (env-only — no backend config API) ---
# Enable email/OTP auth on /login (default true).
VITE_AUTH_EMAIL=true
# Enable Google OAuth on /login (default true).
VITE_AUTH_OAUTH_GOOGLE=true
# Enable GitHub OAuth on /login (default true).
VITE_AUTH_OAUTH_GITHUB=true
# Enable Apple OAuth on /login (default false).
VITE_AUTH_OAUTH_APPLE=false
# Auto-start Google OAuth on /login; requires VITE_AUTH_OAUTH_GOOGLE not false (default false).
VITE_AUTH_OAUTH_AUTO_GOOGLE=false
# Enable passkey/WebAuthn auth on /login (default true).
VITE_AUTH_PASSKEY=true

# --- CAPTCHA ---
# "true" disables the Turnstile CAPTCHA (local dev; pair with the core-be test secret).
VITE_CAPTCHA_DISABLED=
# Cloudflare Turnstile site key; required in production unless VITE_CAPTCHA_DISABLED is true.
VITE_TURNSTILE_SITE_KEY=
# Local-dev always-pass test key: 1x00000000000000000000AA

# --- Platform: environment identity ---
# Reported environment: local (default) | development | production. The env vocabulary, not the Vite mode; reported-only (Sentry/PostHog tag), never branched on.
VITE_APP_ENV=

# --- Platform: diagnostics / dev tooling (env-driven; production-safe defaults) ---
# "true" emits [Module] diagnostic console logs (on locally and in the development deploy, off in production).
VITE_DEBUG_LOGGING=false
# "true" mounts React Query Devtools + the localhost debug panel + theme-shuffle shortcut.
VITE_DEVTOOLS=false
# "true" installs Playwright E2E hooks on globalThis (navigateInApp, establishSession).
VITE_E2E_HOOKS=false
# "true" polls /version.json for new deployments (off locally, on in deployed envs; never started by the test runner).
VITE_VERSION_CHECK=true

# --- App build metadata ---
# App version string; read by vite.config.ts (names the Sentry release, fallback 0.0.0) and the client. CI-set; blank locally.
VITE_APP_VERSION=
#
# Build-INJECTED (Vite `define` — do NOT set here; a value in .env is ignored):
#   VITE_APP_BUILD_ID          build hash            (plugins/version-json.ts)
#   VITE_I18N_BUILD_MODE       from BUILD_I18N_MODE   (plugins/i18n-build.ts)
#   VITE_I18N_BUILD_BCP47      from BUILD_I18N_LOCALE (plugins/i18n-build.ts)
#   VITE_I18N_BUILD_UI_LOCALE  from BUILD_I18N_LOCALE (plugins/i18n-build.ts)

# --- Build-time i18n (BUILD_*, not exposed as VITE_) ---
# i18n build mode: single (inline one locale into JS) or multi (lazy JSON per locale).
BUILD_I18N_MODE=single
# Primary i18n build locale, BCP-47 (e.g. en-US).
BUILD_I18N_LOCALE=en-US

# --- CI / toolchain ---
# Node version for CI/build; keep in lock step with .nvmrc.
NODE_VERSION=24
# Netlify site ID (deploy target).
NETLIFY_SITE_ID=



# GitHub Actions PAT (repository secret) for release-please, dependabot-auto-merge, and the weekly PAT canary. Set via `gh secret set RELEASE_PLEASE_TOKEN --repo` (no --env); CI only — never bundled or read locally.
RELEASE_PLEASE_TOKEN=