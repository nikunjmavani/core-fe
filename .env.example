# ─────────────────────────────────────────────────────────────────────────────
# Core Frontend — Environment variables reference (the ONLY committed env file)
# `pnpm setup:local` scaffolds .env.development from this. There is NO .env.local —
# .env.development is the single gitignored local file (behavior flags + secrets).
# Local dev runs in development mode; deploys inject env from GitHub Environments.
# Canonical runbook: docs/deployment/runbooks/environment-variables.md
#
# Branch-wise env contracts (envProfiles in src/core/config/env-schema.ts,
# enforced by `pnpm validate:client-env`):
#   dev  → development (.env.development) · main → production (.env.production)
# Each environment has required keys (must be set) and forbidden keys. Forbidden
# keys (SONAR_*, wrong-env pk_test_/pk_live_ Stripe) are checked only against
# git-TRACKED .env/.env.<env> files — gitignored local files are skipped, so the
# secrets in your local .env.development never trip the guard.
# ─────────────────────────────────────────────────────────────────────────────

# ############################################################
# GitHub Secrets (Netlify / GitHub Actions — sensitive)
# ############################################################

# --- Build / deploy ---
SENTRY_AUTH_TOKEN=
# Sentry source map upload (see docs/integrations/sentry-sourcemaps.md)

SENTRY_ORG=
SENTRY_PROJECT=

NETLIFY_AUTH_TOKEN=
# Netlify CLI deploy token (CI only).

# --- Local MCP (Cursor / Claude — not bundled into the app) ---
CONTEXT7_API_KEY=
# Context7 docs MCP — https://context7.com/dashboard — read via ${CONTEXT7_API_KEY} in .mcp.json

# --- Local SonarQube quality gate (development only — never set in CI) ---
SONAR_ADMIN_PASSWORD=
SONAR_TOKEN=
# Auto-managed in .env.local by the local Sonar gate (tooling/sonar/sonar-gate.mjs).
# See docs/reference/quality/sonarqube-local.md.

# ############################################################
# GitHub Variables (public or operational knobs)
# ############################################################

# --- API ---
VITE_API_BASE_URL=
# Production API base URL (e.g. https://api.example.com). Empty = same-origin.
# OPTIONAL — required in production when API is not same-origin.

VITE_DEV_API_URL=http://localhost:3000
# Dev server only: Vite proxy target for /api.

# --- Observability (public client keys) ---
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=
# PostHog analytics (optional). Analytics cookies are gated behind consent.

VITE_CSP_REPORT_URI=
# CSP violation collector (optional). See docs/deployment/runbooks/csp-trusted-types-production.md

# --- Payments (public client key) ---
VITE_STRIPE_PUBLISHABLE_KEY=
# Stripe publishable key (pk_test_… in sandbox/test, pk_live_… in prod). Public, safe to expose.

# --- App chrome ---
VITE_LAYOUT_WIDTH=contained
# "contained" (default), "full", or "reading".

VITE_THEME_LOCK=
# "true" hides runtime theme switcher + shuffle.

VITE_PRIVACY_POLICY_URL=

# --- Platform: feature modules ---
VITE_DISABLED_MODULES=
# Comma-separated module keys to disable (e.g. billing,members). Routes 404 via L6b gate.

VITE_PERSONAL_ORGANIZATIONS=
# Tri-state override for personal org deployment mode (true/false/unset).

VITE_TEAM_ORGANIZATIONS=
# Tri-state override for team org deployment mode (true/false/unset).

# --- Platform: auth methods (env-only — no backend config API) ---
VITE_AUTH_EMAIL_PASSWORD=true
VITE_AUTH_EMAIL=true
VITE_AUTH_OAUTH_GOOGLE=true
VITE_AUTH_OAUTH_GITHUB=true
VITE_AUTH_OAUTH_APPLE=false
VITE_AUTH_OAUTH_AUTO_GOOGLE=false
VITE_AUTH_PASSKEY=true

# --- CAPTCHA ---
VITE_CAPTCHA_DISABLED=
# Cloudflare always-pass test key for local dev (pair with core-be test secret).
# VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
VITE_TURNSTILE_SITE_KEY=
# OPTIONAL — required in production when VITE_CAPTCHA_DISABLED is not true.

# --- Platform: diagnostics / dev tooling (env-driven; production-safe defaults) ---
# Behavior is never sniffed from the build mode — each is a named flag. The local
# .env.development file flips them on for development; deployed builds keep defaults.
VITE_DEBUG_LOGGING=false
# "true" emits [Module] diagnostic console logs. On locally, off in deployed builds.
VITE_DEVTOOLS=false
# "true" mounts React Query Devtools + localhost debug panel + theme-shuffle shortcut.
VITE_E2E_HOOKS=false
# "true" installs Playwright E2E hooks on globalThis (navigateInApp, establishSession).
VITE_VERSION_CHECK=true
# "true" polls /version.json for new deployments. Off locally/tests, on in deployed envs.

# --- Build-time i18n (BUILD_*, not exposed as VITE_) ---
BUILD_I18N_MODE=single
BUILD_I18N_LOCALE=en-US

# --- CI / toolchain ---
NODE_VERSION=24
# Keep in lock step with .nvmrc.

NETLIFY_SITE_ID=

# --- Docker runtime (docker-entrypoint.sh → window.__CONFIG__) ---
# At deploy, strip VITE_ prefix when writing config.js keys (see public/config.js).
# API_BASE_URL=
# SENTRY_DSN=
# POSTHOG_KEY=
# POSTHOG_HOST=
