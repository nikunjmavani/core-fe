# ─────────────────────────────────────────────────────────────────────────────
# Core Frontend — Environment variables reference
# Copy to .env or .env.local and set values. Never commit secrets.
# See docs/DEPLOYMENT.md for production and Docker.
# ─────────────────────────────────────────────────────────────────────────────

# ── Build-time (Vite): exposed to client (VITE_ prefix) ───────────────────────
# Used when running pnpm build or by static hosts that inject at build.

VITE_API_BASE_URL=
# Production API base URL (e.g. https://api.example.com). Empty = same-origin.


VITE_DEV_API_URL=http://localhost:3000
# Dev server only: Vite proxy target for /api.

VITE_SENTRY_DSN=
# Sentry DSN for client error tracking (optional).

VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=
# PostHog analytics (optional). Host e.g. https://us.i.posthog.com

# ── Build-time only (no VITE_ prefix): not exposed to client ──────────────────

NODE_VERSION=22
# Node version for CI/build (e.g. Doppler, Netlify).
# Sentry source map upload (see docs/SENTRY_SOURCEMAPS.md)

# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# VITE_APP_VERSION=1.0.0

# ── Docker runtime (docker-entrypoint.sh) ──────────────────────────────────────
# Set when running the container; written to window.__CONFIG__ (config.js).
# Same image can be used for staging/production with different env.

# API_BASE_URL=
# SENTRY_DSN=
# POSTHOG_KEY=
# POSTHOG_HOST=
