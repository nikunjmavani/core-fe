// markdownlint-cli2 configuration (same shape as core-be's).
//
// `config` references the rule set in `.markdownlint.json` (kept separate so
// editors / DavidAnson.vscode-markdownlint pick it up automatically).
//
// `globs` and `ignores` are the canonical place to control which files are
// linted. We do not use a separate `.markdownlintignore` file — this is the
// SINGLE source of truth.
{
  "$schema": "https://raw.githubusercontent.com/DavidAnson/markdownlint-cli2/main/schema/markdownlint-cli2-config-schema.json",
  "config": ".markdownlint.json",
  "globs": ["**/*.md"],
  "ignores": [
    "node_modules/**",
    "dist/**",
    "coverage/**",
    "test-results/**",
    "reports/**",
    ".stryker-tmp/**",
    "CHANGELOG.md",
    // release-please generates the dev-channel changelog too (asterisk bullets).
    "CHANGELOG-dev.md",
    ".github/PULL_REQUEST_TEMPLATE.md",
    // Generated by `pnpm env:catalog` (drift-gated by `env:catalog:check`) — a
    // markdownlint/Prettier rewrite would break the byte-exact regeneration check.
    "docs/reference/env-catalog.md",
    ".claude/**",
    ".netlify/**",
    ".pnpm-store/**",
    // Vendored/agent-managed surface (skills installed via `pnpm dlx skills add`,
    // cursor rules, agent docs) — not part of the human docs surface.
    // .cursor/ symlinks into agent-os/, so both spellings must be ignored.
    "agent-os/**",
    ".cursor/**",
    ".agents/**",
  ],
}
