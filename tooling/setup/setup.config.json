{
  "project": {
    "name": "core-fe",
    "displayName": "core-fe",
    "organization": "albetrios"
  },
  "git": {
    "protectedBranches": ["main"],
    "defaultBranch": "main"
  },
  "environments": [
    {
      "name": "development",
      "label": "Development",
      "viteMode": "development",
      "protected": true,
      "isDefault": true,
      "cookieBanner": {
        "captureConsentEvents": true,
        "posthogEventName": "analytics_consent_decision"
      },
      "deploySecretsRequired": [
        "VITE_API_BASE_URL",
        "NETLIFY_AUTH_TOKEN",
        "NETLIFY_SITE_ID"
      ],
      "deploySecrets": [
        "VITE_API_BASE_URL",
        "VITE_POSTHOG_KEY",
        "VITE_POSTHOG_HOST",
        "VITE_PRIVACY_POLICY_URL",
        "NETLIFY_AUTH_TOKEN",
        "NETLIFY_SITE_ID"
      ]
    },
    {
      "name": "production",
      "label": "Production",
      "viteMode": "production",
      "protected": true,
      "cookieBanner": {
        "captureConsentEvents": true,
        "posthogEventName": "analytics_consent_decision"
      },
      "deploySecretsRequired": [
        "VITE_API_BASE_URL",
        "NETLIFY_AUTH_TOKEN",
        "NETLIFY_SITE_ID"
      ],
      "deploySecrets": [
        "VITE_API_BASE_URL",
        "VITE_POSTHOG_KEY",
        "VITE_POSTHOG_HOST",
        "VITE_PRIVACY_POLICY_URL",
        "NETLIFY_AUTH_TOKEN",
        "NETLIFY_SITE_ID"
      ]
    }
  ],
  "providers": {
    "netlify": {
      "enabled": true
    },
    "github": {
      "enabled": true,
      "repository": "nikunjmavani/core-fe"
    }
  }
}
