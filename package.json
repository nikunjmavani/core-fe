{
  "name": "core-fe",
  "private": true,
  "version": "1.0.0-dev.3",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:check": "node tooling/ci/check-preload-graph.mjs",
    "preview": "vite preview",
    "preview:https": "vite preview --https",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "biome:check": "biome check .",
    "biome:fix": "biome check --write .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "type-check": "tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:security": "vitest run --project security",
    "test:ci-policy": "vitest run --project ci-policy",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "rm -rf test-results 2>/dev/null || true && playwright test",
    "test:e2e:integration": "playwright test tests/e2e/routes-integration.e2e.test.ts tests/e2e/org-switching.e2e.test.ts",
    "test:e2e:integration:cross-browser": "playwright test --config playwright.integration-cross-browser.config.ts",
    "test:cross-browser": "playwright test --config playwright.cross-browser.config.ts",
    "test:e2e:report": "playwright show-report test-results/report",
    "security:secrets": "gitleaks detect --source . -v",
    "security:sast": "semgrep --config auto .",
    "tsdoc:check": "node tooling/tsdoc-coverage/check-coverage.mjs",
    "tsdoc:check:report": "node tooling/tsdoc-coverage/check-coverage.mjs --report",
    "tsdoc:check:refresh-budget": "node tooling/tsdoc-coverage/check-coverage.mjs --refresh-budget",
    "knip": "knip",
    "docs:lint": "markdownlint-cli2",
    "docs:lint:fix": "markdownlint-cli2 --fix",
    "docs:lint:changed": "bash tooling/ci/lint-changed-markdown.sh",
    "sonar:up": "docker compose -f docker-compose.sonar.yml up -d sonarqube",
    "sonar:down": "docker compose -f docker-compose.sonar.yml down",
    "sonar:reset": "docker compose -f docker-compose.sonar.yml down -v",
    "sonar:scan": "node tooling/sonar/sonar-gate.mjs",
    "quality": "pnpm health && pnpm sonar:scan",
    "clean": "rm -rf dist coverage test-results node_modules/.tmp node_modules/.vite",
    "size": "node tooling/ci/run-size-limit.mjs",
    "size:check": "node tooling/ci/run-size-limit.mjs --json",
    "build:analyze": "ANALYZE=true vite build",
    "validate": "pnpm lint && pnpm biome:check && pnpm type-check && pnpm test",
    "test:ci": "vitest run --coverage",
    "contracts:drift": "node tooling/ci/check-api-contract-drift.mjs",
    "coverage:patch": "node tooling/ci/check-patch-coverage.mjs --coverage coverage/coverage-final.json",
    "deps:check": "pnpm outdated",
    "deps:audit": "pnpm audit --audit-level=high",
    "deps:audit:prod": "pnpm audit --prod --audit-level=high",
    "sbom:generate": "npx -y @cyclonedx/cdxgen -t js --no-recurse -o sbom.cyclonedx.json .",
    "deploy:netlify": "pnpm build && netlify deploy",
    "deploy:netlify:prod": "pnpm build && netlify deploy --prod",
    "setup:local": "tsx tooling/dev/setup-local.ts",
    "mcp:setup": "tsx tooling/dev/setup-mcp.ts",
    "mcp:setup:default": "tsx tooling/dev/setup-mcp.ts --default",
    "mcp:setup:check": "tsx tooling/dev/setup-mcp.ts --check",
    "mcp:setup:list": "tsx tooling/dev/setup-mcp.ts --list",
    "setup": "node tooling/setup/live/index.mjs live",
    "setup:check": "node tooling/setup/live/index.mjs check",
    "setup:revert:all": "node tooling/setup/live/index.mjs revert",
    "gh:rulesets:sync": "node tooling/setup/github/sync-rulesets.mjs",
    "gh:rulesets:sync:dry-run": "node tooling/setup/github/sync-rulesets.mjs --dry-run",
    "gh:rulesets:check": "node tooling/setup/github/sync-rulesets.mjs --check",
    "github:sync": "node tooling/setup/github/sync.mjs",
    "github:sync:dry-run": "node tooling/setup/github/sync.mjs --dry-run",
    "github:sync:check": "node tooling/setup/github/sync.mjs --check",
    "validate:github-env": "node tooling/setup/github/validate-github-env.mjs",
    "validate:github-environments": "node tooling/setup/github/check-environments-drift.mjs",
    "test:github-scripts": "node --import tsx --test tooling/setup/github/**/*.test.mjs tooling/dev/**/*.test.ts tooling/validate/*.test.mjs",
    "setup:infra:netlify": "./tooling/setup/netlify.sh",
    "setup:infra:github-secrets": "./tooling/setup/github-secrets.sh",
    "tool:sync-env-example": "tsx tooling/validate/sync-env-example.ts",
    "tool:sync-env-example:fix": "tsx tooling/validate/sync-env-example.ts --fix",
    "validate:env-example": "./tooling/validate/env-example.sh",
    "validate:public": "./tooling/validate/public-assets.sh",
    "validate:structure": "./tooling/validate/route-islands.sh",
    "validate:tokens": "./tooling/validate/design-tokens.sh",
    "validate:theme-axis": "./tooling/validate/theme-axis.sh",
    "validate:theme-catalog": "node --import tsx tooling/validate/theme-catalog.mjs",
    "validate:testids": "node tooling/validate/test-ids.mjs",
    "validate:i18n": "node tooling/validate/i18n-keys.mjs",
    "validate:vite-env": "node tooling/validate/vite-env-reads.mjs",
    "validate:client-env": "node --import tsx tooling/validate/client-env.ts",
    "health": "./tooling/validate/health-check.sh",
    "health:fix": "./tooling/validate/health-check.sh --fix",
    "report:code-review": "node tooling/reports/code-review-report.mjs",
    "before-commit-guard": "./tooling/validate/before-commit-guard.sh",
    "agent-os:generate": "node tooling/agent-os/generate.mjs --write",
    "agent-os:generate:check": "node tooling/agent-os/generate.mjs --check",
    "agent-os:check": "node agent-os/evals/check.mjs",
    "agent-os:check:report": "node agent-os/evals/check.mjs --report",
    "agent-os:triggers": "node agent-os/evals/trigger-eval.mjs",
    "agent-os:triggers:strict": "node agent-os/evals/trigger-eval.mjs --strict",
    "test:visual": "rm -rf test-results && playwright test tests/e2e/visual.e2e.test.ts",
    "test:visual:update": "rm -rf test-results && playwright test tests/e2e/visual.e2e.test.ts --update-snapshots",
    "prepare": "husky"
  },
  "pnpm": {
    "overrides": {
      "basic-ftp": "5.3.1",
      "esbuild": ">=0.28.1",
      "protobufjs": "7.6.4",
      "minimatch": "10.2.5",
      "multiparty": ">=4.3.0",
      "tmp": ">=0.2.6",
      "dompurify": ">=3.4.7",
      "undici@7": "^7.28.0",
      "ws": ">=8.21.0",
      "http-proxy-middleware": ">=3.0.7",
      "@modelcontextprotocol/sdk": ">=1.25.2"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint-plugin-jsx-a11y>eslint": "10"
      }
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome check --no-errors-on-unmatched",
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@phosphor-icons/react": "^2.1.10",
    "@sentry/react": "^10.63.0",
    "@stripe/react-stripe-js": "^6.7.0",
    "@stripe/stripe-js": "^9.9.0",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "~1.160.2",
    "@tanstack/react-table": "^8.21.3",
    "animejs": "^4.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "culori": "^4.0.2",
    "embla-carousel-react": "^8.6.0",
    "i18next": "^26.3.4",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.23.0",
    "posthog-js": "^1.396.6",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.6.1",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-hook-form": "^7.80.0",
    "react-i18next": "^17.0.8",
    "recharts": "^3.9.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "web-vitals": "^5.3.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@babel/core": "^8.0.1",
    "@biomejs/biome": "2.5.2",
    "@colbymchenry/codegraph": "^1.2.0",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.5.0",
    "@playwright/test": "^1.61.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@sentry/vite-plugin": "^5.3.0",
    "@size-limit/file": "^12.1.0",
    "@size-limit/preset-app": "^12.1.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__core": "^7.20.5",
    "@types/culori": "^4.0.1",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@upstash/context7-mcp": "^3.2.2",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "knip": "^6.24.0",
    "lint-staged": "^17.0.8",
    "markdownlint-cli2": "0.23.0",
    "netlify-cli": "^26.1.0",
    "pg": "^8.22.0",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "shadcn": "^4.12.0",
    "size-limit": "^12.1.0",
    "tailwindcss": "^4.3.2",
    "tailwindcss-mcp-server": "^0.1.1",
    "tsx": "^4.22.5",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9",
    "vitest-axe": "^0.1.0",
    "workbox-build": "^7.4.1",
    "workbox-expiration": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1",
    "workbox-window": "^7.4.1"
  }
}
