#
# Core Frontend — Setup Config (Live Automation)
#
# Non-secret configuration for one-command deployment. Safe to commit.
# Used by: pnpm run setup | setup:check | setup:revert:all
#
# Required in this file: NODE_VERSION (CI / Netlify alignment)
# Required env (set once, never commit): NETLIFY_AUTH_TOKEN
# Optional: GITHUB_TOKEN (or use 'gh auth login' for gh commands)
#
# Branch / environment model matches core-be (see scripts/setup/setup.config.json):
#   dev  → GitHub environment development
#   main → GitHub environment production
#

########################################
# Identity
########################################

# Project name (slug). Used for Netlify sites, etc.
SETUP_PROJECT_NAME=core-fe

# Netlify team/account slug. Find in Netlify URL: app.netlify.com/teams/<THIS>/sites
SETUP_ORG_NAME=albetrios

# Node version for CI and builds
NODE_VERSION=24

########################################
# Environments
########################################

# Comma-separated: dev,main,preview
# Each env gets: Netlify site, branch mapping
#   dev -> branch dev (GitHub env development) | main -> branch main (GitHub env production) | preview -> PR previews
SETUP_ENVS=dev,main


########################################
# API base URLs per environment
########################################

# Production API (current backend)
VITE_API_BASE_URL_PROD=https://your-api-domain.com

# Development API
VITE_API_BASE_URL_DEV=https://your-api-domain.com

# Cookie banner + analytics (optional — per GitHub Environment: development / production)
VITE_POSTHOG_HOST=https://us.i.posthog.com
VITE_POSTHOG_KEY_DEV=
VITE_POSTHOG_KEY_PROD=
VITE_PRIVACY_POLICY_URL_DEV=
VITE_PRIVACY_POLICY_URL_PROD=

# Demo mode (must be false in production)
VITE_DEMO_MODE_PROD=false
VITE_DEMO_MODE_DEV=false


########################################
# Netlify site names (informational)
########################################

# ONE Netlify project serves every environment via deploy contexts:
# main → production deploy (--prod), dev → alias deploy (--alias dev).
# The actual site ID lives in Netlify and both GitHub Environments' secrets.
NETLIFY_SITE_MAIN=core-fe
NETLIFY_SITE_DEV=core-fe
NETLIFY_SITE_PREVIEW=core-fe
