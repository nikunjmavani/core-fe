{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp", "--api-key", "YOUR_CONTEXT7_API_KEY"]
    },
    "shadcn": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"]
    },
    "tailwindcss": {
      "command": "npx",
      "args": ["-y", "tailwindcss-mcp-server"]
    },
    "github": {
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {}
    },
    "core-be-api": {
      "url": "http://localhost:3000/api/v1/mcp"
    },
    "neon": {
      "url": "https://mcp.neon.tech/mcp",
      "headers": {}
    },
    "sentry": {
      "url": "https://mcp.sentry.dev/mcp",
      "headers": {}
    },
    "railway": {
      "command": "npx",
      "args": ["-y", "@railway/mcp-server"]
    },
    "aws": {
      "command": "uvx",
      "args": [
        "mcp-proxy-for-aws@latest",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--metadata",
        "AWS_REGION=ap-south-1"
      ]
    },
    "stripe": {
      "url": "https://mcp.stripe.com",
      "headers": {}
    },
    "semgrep": {
      "command": "uvx",
      "args": ["semgrep-mcp"]
    },
    "sonarqube": {
      "command": "docker",
      "args": [
        "run",
        "--init",
        "--pull=always",
        "--rm",
        "-i",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_URL",
        "mcp/sonarqube"
      ]
    },
    "redis": {
      "command": "uvx",
      "args": [
        "--from",
        "redis-mcp-server@latest",
        "redis-mcp-server",
        "--url",
        "${REDIS_URL}"
      ]
    },
    "postman": {
      "url": "https://mcp.postman.com/mcp",
      "headers": {}
    },
    "resend": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "-e", "RESEND_API_KEY", "mcp/resend"]
    },
    "codegraph": {
      "type": "stdio",
      "command": "codegraph",
      "args": ["serve", "--mcp"]
    },
    "headroom": {
      "type": "stdio",
      "command": "headroom",
      "args": ["mcp", "serve"]
    }
  }
}
