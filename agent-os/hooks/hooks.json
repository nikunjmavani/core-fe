{
  "description": "Single source of truth for core-fe agent hook wiring (self-contained; no other repo). Mirrored into .claude/settings.json (hooks block) and .cursor/hooks.json. Each entry may target Claude and/or Cursor; an agent only gets a hook for events it supports. All hooks FAIL OPEN — a hook error never bricks the session.",
  "hooks": [
    {
      "id": "session-start",
      "runtime": "bash",
      "script": "session-start.sh",
      "claude": { "event": "SessionStart" }
    },
    {
      "id": "prompt-skill-router",
      "runtime": "bash",
      "script": "prompt-skill-router.sh",
      "claude": { "event": "UserPromptSubmit" }
    },
    {
      "id": "guard-edits",
      "runtime": "bash",
      "script": "guard-edits.sh",
      "claude": { "event": "PreToolUse", "matcher": "Edit|Write|MultiEdit" }
    },
    {
      "id": "guardrails",
      "runtime": "node",
      "script": "guardrails.mjs",
      "claude": { "event": "PreToolUse", "matcher": "Bash|Edit|Write" }
    },
    {
      "id": "no-unrequested-pr",
      "runtime": "bash",
      "script": "no-unrequested-pr.sh",
      "claude": { "event": "PreToolUse", "matcher": "mcp__github__create_pull_request" }
    },
    {
      "id": "format-edits",
      "runtime": "bash",
      "script": "format-edits.sh",
      "claude": { "event": "PostToolUse", "matcher": "Edit|Write" }
    },
    {
      "id": "skill-reminder",
      "runtime": "bash",
      "script": "skill-reminder.sh",
      "claude": { "event": "PostToolUse", "matcher": "Edit|Write" }
    },
    {
      "id": "gate-failure-hint",
      "runtime": "bash",
      "script": "gate-failure-hint.sh",
      "note": "PostToolUseFailure — wire only on agents that support a tool-failure event; omitted from .claude/settings.json to avoid nagging on successful gate runs."
    },
    {
      "id": "stop-gate-reminder",
      "runtime": "bash",
      "script": "stop-gate-reminder.sh",
      "claude": { "event": "Stop" }
    },
    {
      "id": "pre-compact-preserve",
      "runtime": "bash",
      "script": "pre-compact-preserve.sh",
      "claude": { "event": "PreCompact" }
    },
    {
      "id": "session-end",
      "runtime": "bash",
      "script": "session-end.sh",
      "claude": { "event": "SessionEnd" }
    },
    {
      "id": "cursor-shell-guard",
      "runtime": "node",
      "script": "cursor-shell-guard.mjs",
      "cursor": { "event": "beforeShellExecution" }
    }
  ]
}
