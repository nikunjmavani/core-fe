{
  "description": "Single source of truth for core-fe agent hook wiring. tooling/agent-os/generate.mjs derives agent-os/platforms/claude/settings.json (hooks block), agent-os/platforms/cursor/hooks.json, and agent-os/platforms/codex/hooks.json from this manifest + agent-os/platforms/targets.json. Tool dirs (.claude/, .cursor/, .codex/) symlink into agent-os/platforms/ — edit here only. All hooks FAIL OPEN.",
  "hooks": [
    {
      "id": "session-start",
      "runtime": "bash",
      "script": "session-start.sh",
      "claude": { "event": "SessionStart" },
      "codex": {
        "event": "SessionStart",
        "matcher": "startup|resume",
        "statusMessage": "Loading core-fe session context"
      }
    },
    {
      "id": "prompt-skill-router",
      "runtime": "bash",
      "script": "prompt-skill-router.sh",
      "claude": { "event": "UserPromptSubmit" },
      "codex": {
        "event": "UserPromptSubmit",
        "statusMessage": "Checking core-fe skill routing"
      }
    },
    {
      "id": "guard-edits",
      "runtime": "bash",
      "script": "guard-edits.sh",
      "claude": { "event": "PreToolUse", "matcher": "Edit|Write|MultiEdit" }
    },
    {
      "id": "guardrails",
      "runtime": "node",
      "script": "guardrails.mjs",
      "claude": { "event": "PreToolUse", "matcher": "Bash|Edit|Write" },
      "codex": {
        "event": "PreToolUse",
        "matcher": "^Bash$",
        "statusMessage": "Checking core-fe shell guardrails"
      }
    },
    {
      "id": "no-unrequested-pr",
      "runtime": "bash",
      "script": "no-unrequested-pr.sh",
      "claude": { "event": "PreToolUse", "matcher": "mcp__github__create_pull_request" }
    },
    {
      "id": "format-edits",
      "runtime": "bash",
      "script": "format-edits.sh",
      "claude": { "event": "PostToolUse", "matcher": "Edit|Write" }
    },
    {
      "id": "skill-reminder",
      "runtime": "bash",
      "script": "skill-reminder.sh",
      "claude": { "event": "PostToolUse", "matcher": "Edit|Write" }
    },
    {
      "id": "gate-failure-hint",
      "runtime": "bash",
      "script": "gate-failure-hint.sh",
      "claude": { "event": "PostToolUseFailure", "matcher": "Bash" }
    },
    {
      "id": "stop-gate-reminder",
      "runtime": "bash",
      "script": "stop-gate-reminder.sh",
      "claude": { "event": "Stop" },
      "codex": {
        "event": "Stop",
        "statusMessage": "Checking core-fe completion gates"
      }
    },
    {
      "id": "pre-compact-preserve",
      "runtime": "bash",
      "script": "pre-compact-preserve.sh",
      "claude": { "event": "PreCompact" }
    },
    {
      "id": "session-end",
      "runtime": "bash",
      "script": "session-end.sh",
      "claude": { "event": "SessionEnd" }
    },
    {
      "id": "cursor-shell-guard",
      "runtime": "node",
      "script": "cursor-shell-guard.mjs",
      "cursor": { "event": "beforeShellExecution" }
    }
  ]
}
