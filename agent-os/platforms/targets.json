{
  "description": "Capability registry — one row per AI coding agent. tooling/agent-os/generate.mjs iterates this to compile each agent's native wiring FROM the common agent-os/ dirs (skills, agents, rules, hooks, mcp, docs). Onboarding a new agent = add a row here; the generator emits only the capabilities the agent supports.",
  "agents": {
    "claude": {
      "label": "Claude Code",
      "entrypoint": ".claude/",
      "consumes": ["skills", "agents", "hooks", "mcp", "docs"],
      "hooksTarget": "agent-os/platforms/claude/settings.json",
      "capabilities": {
        "skills": true,
        "subagents": true,
        "plugins": true,
        "outputStyles": false,
        "mcpFormat": "json",
        "hookEvents": [
          "SessionStart",
          "UserPromptSubmit",
          "PreToolUse",
          "PostToolUse",
          "PostToolUseFailure",
          "Stop",
          "SessionEnd",
          "PreCompact",
          "SubagentStop"
        ],
        "agentsMd": { "linkFollow": true, "maxBytes": null, "overrideFile": null }
      }
    },
    "cursor": {
      "label": "Cursor",
      "entrypoint": ".cursor/",
      "consumes": ["skills", "agents", "rules", "hooks", "mcp"],
      "hooksTarget": "agent-os/platforms/cursor/hooks.json",
      "capabilities": {
        "skills": true,
        "subagents": true,
        "plugins": false,
        "outputStyles": false,
        "mcpFormat": "json",
        "hookEvents": [
          "beforeShellExecution",
          "afterFileEdit",
          "beforeReadFile",
          "beforeMCPExecution",
          "beforeSubmitPrompt",
          "stop"
        ],
        "agentsMd": { "linkFollow": true, "maxBytes": null, "overrideFile": null }
      }
    },
    "codex": {
      "label": "Codex",
      "entrypoint": "AGENTS.md",
      "consumes": ["skills", "hooks", "docs"],
      "hooksTarget": "agent-os/platforms/codex/hooks.json",
      "capabilities": {
        "skills": true,
        "subagents": false,
        "plugins": false,
        "outputStyles": false,
        "hookEvents": [
          "SessionStart",
          "UserPromptSubmit",
          "PreToolUse",
          "PostToolUse",
          "Stop"
        ],
        "agentsMd": { "linkFollow": false, "maxBytes": 32768, "overrideFile": null }
      }
    }
  }
}
