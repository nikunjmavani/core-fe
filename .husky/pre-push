#!/usr/bin/env sh
# Fast gate before push — full suite runs in CI (.github/workflows/pr-ci.yml).

pnpm biome:check
pnpm type-check
pnpm build
pnpm build:check

# Markdown lint on the pushed diff (mirrors the Docs lint CI lane). lint-staged
# only formats staged markdown; this lints every changed file in the push.
# Default base is origin/main; override with LINT_BASE=<ref>.
PUSHED_MD=$(git diff --name-only @{u}...HEAD 2>/dev/null | grep -E '\.md$' || true)
if [ -n "$PUSHED_MD" ]; then
  pnpm docs:lint:changed
else
  echo "Skipping changed-markdown lint on pre-push (no markdown changes)."
fi

# Unit tests (matches the CI unit lane).
# Run only when pushed commits include unit-relevant files.
PUSHED_UNIT_RELEVANT=$(git diff --name-only @{u}...HEAD 2>/dev/null | grep -E \
  '^(src/|tests/utils/|vitest\.config\.ts$|package\.json$|pnpm-lock\.yaml$)' || true)
if [ -n "$PUSHED_UNIT_RELEVANT" ]; then
  pnpm test
else
  echo "Skipping unit tests on pre-push (no unit-relevant changes)."
fi

# API contract drift — every endpoint this app references must exist in
# core-be's committed route catalog (skips with a notice when the sibling
# core-be checkout is absent). Catches endpoint typos before they ship.
pnpm contracts:drift

# SonarQube quality gate — scans against the local SonarQube server and BLOCKS the push if any
# unresolved Sonar issue exists. Runs only when the pushed commits touch deployed-surface code
# (src/ runtime — the only thing Sonar analyzes; tests/mocks/fixtures/scripts are excluded). The
# gate auto-starts the server on first use (first boot ~2 min) and provisions a token in
# .env.local. There is no per-gate skip: a red Sonar gate must be fixed, not bypassed.
SONAR_BASE=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || echo origin/main)
PUSHED_RUNTIME=$(git diff --name-only "$SONAR_BASE"...HEAD 2>/dev/null | grep -E '^src/.*\.(ts|tsx)$' | \
  grep -Ev '(__tests__/|\.test\.tsx?$|\.spec\.tsx?$|\.fixtures\.ts$|/mock-[^/]*\.ts$|\.d\.ts$)' || true)
if [ -n "$PUSHED_RUNTIME" ]; then
  pnpm sonar:scan
else
  echo "Skipping SonarQube gate on pre-push (no deployed-surface code changes)."
fi
