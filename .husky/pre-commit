#!/usr/bin/env sh

# ── Before-commit guard (env, public assets, lint-staged, type-check) ──
./scripts/validate/before-commit-guard.sh

# ── Gitleaks secret scan on staged files (if installed) ──
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --config .gitleaks.toml --verbose
else
  echo "NOTICE: gitleaks not installed. Skipping secret scan."
  echo "Install with: brew install gitleaks"
fi

# ── Reject merge conflict markers ──
# Git writes `<<<<<<< <label>` / `>>>>>>> <label>` (trailing space) and a bare
# 7-char `=======` line — anchored exactly so doc banner lines (`====…`) pass.
CONFLICT_FILES=$(git diff --cached --name-only -z | xargs -0 grep -rlE '^(<{7} |>{7} |={7}$)' -- 2>/dev/null || true)
if [ -n "$CONFLICT_FILES" ]; then
  echo "ERROR: Merge conflict markers found in:"
  echo "$CONFLICT_FILES"
  exit 1
fi

# ── Reject large files (>1MB) ──
LARGE_FILES=$(git diff --cached --name-only --diff-filter=d | while read -r f; do
  SIZE=$(wc -c < "$f" 2>/dev/null | tr -d ' ')
  if [ "$SIZE" -gt 1048576 ]; then echo "  $f ($SIZE bytes)"; fi
done)
if [ -n "$LARGE_FILES" ]; then
  echo "ERROR: Files exceed 1MB limit:"
  echo "$LARGE_FILES"
  exit 1
fi
